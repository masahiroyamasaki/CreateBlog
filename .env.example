ANTHROPIC_API_KEY=your_api_key_here
FLASK_SECRET_KEY=your_secret_key_here
FLASK_DEBUG=True

# Google Sheets 連携（OAuth2）
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=authorized_user.json

# ── 新システム ─────────────────────────────────────────────
SECRET_KEY=your_secret_key_here   # FLASK_SECRET_KEY と同じ値でOK（暗号化キー兼用）

# MySQL (ConoHa WING)
MYSQL_HOST=mysqlXXX.conoha.ne.jp
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=blog_ig_system

# Google Cloud Imagen（画像生成）
GCP_SERVICE_ACCOUNT_FILE=gcp_service_account.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Instagram Graph API バージョン
IG_API_VERSION=v20.0
